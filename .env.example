# Anthropic API key for the natural-language agent.
# If unset, the engine runs in offline mode with a rule-based responder.
ANTHROPIC_API_KEY=

# Model used by the agent (defaults to claude-opus-4-8).
AGENT_MODEL=claude-opus-4-8

# Seconds between monitoring ticks.
MONITOR_INTERVAL=2.0

# Set to "1" to require human approval before high-risk treatments run.
REQUIRE_APPROVAL=0
